generator client { provider = "prisma-client-js" } datasource db { provider = "postgresql" url = env("DATABASE_URL") } enum TransactionType { RECEITA DESPESA } enum AlertType { LIMITE_EXCEDIDO GASTO_ALTO } model User { id String @id @default(uuid()) email String @unique nome String senha String criado_em DateTime @default(now()) atualizado_em DateTime @updatedAt transactions Transaction[] categories Category[] bankAccounts BankAccount[] budgets MonthlyBudget[] alerts Alert[] } model Transaction { id String @id @default(uuid()) userId String data DateTime descricao String valor Decimal tipo TransactionType categoria String banco_origem String criado_em DateTime @default(now()) atualizado_em DateTime @updatedAt user User @relation(fields: [userId], references: [id], onDelete: Cascade) @@index([userId]) @@index([data]) } model Category { id String @id @default(uuid()) userId String nome String cor String icone String limite_mensal Decimal? criado_em DateTime @default(now()) atualizado_em DateTime @updatedAt user User @relation(fields: [userId], references: [id], onDelete: Cascade) rules CategoryRule[] alerts Alert[] @@index([userId]) } model CategoryRule { id String @id @default(uuid()) categoria_id String palavra_chave String prioridade Int @default(0) criado_em DateTime @default(now()) category Category @relation(fields: [categoria_id], references: [id], onDelete: Cascade) @@index([categoria_id]) } model BankAccount { id String @id @default(uuid()) userId String nome_banco String tipo_conta String saldo_inicial Decimal @default(0) criado_em DateTime @default(now()) atualizado_em DateTime @updatedAt user User @relation(fields: [userId], references: [id], onDelete: Cascade) @@index([userId]) } model MonthlyBudget { id String @id @default(uuid()) userId String mes Int ano Int limite_total Decimal gasto_total Decimal @default(0) criado_em DateTime @default(now()) atualizado_em DateTime @updatedAt user User @relation(fields: [userId], references: [id], onDelete: Cascade) @@unique([userId, mes, ano]) } model Alert { id String @id @default(uuid()) userId String tipo AlertType categoria_id String? mensagem String lido Boolean @default(false) criado_em DateTime @default(now()) user User @relation(fields: [userId], references: [id], onDelete: Cascade) category Category? @relation(fields: [categoria_id], references: [id], onDelete: SetNull) @@index([userId]) @@index([categoria_id]) }